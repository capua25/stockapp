<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:StockApp.Presentation.Actualizaciones"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="300"
             x:Class="StockApp.Presentation.Actualizaciones.Views.ActualizacionModalView"
             x:DataType="vm:ActualizacionModalViewModel">

    <!-- Modal posponible (severity: important). App usable detrás. -->
    <Border Background="#FFFDF0" BorderBrush="#FF9800" BorderThickness="2"
            CornerRadius="6" Padding="24" HorizontalAlignment="Center" VerticalAlignment="Center"
            Width="480">
        <StackPanel Spacing="16">

            <TextBlock Text="Actualización disponible"
                       FontSize="18" FontWeight="Bold"
                       Foreground="#E65100" />

            <TextBlock Text="{Binding TextoMarkdown}"
                       TextWrapping="Wrap"
                       Opacity="0.85" />

            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                <Button Content="Posponer"
                        Command="{Binding PosponerCommand}"
                        IsVisible="{Binding EsPosponible}" />
                <Button Content="Actualizar ahora"
                        Command="{Binding ActualizarAhoraCommand}"
                        Background="#FF9800"
                        Foreground="White" />
            </StackPanel>

        </StackPanel>
    </Border>

</UserControl>
