<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:StockApp.Presentation.Actualizaciones"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="56"
             x:Class="StockApp.Presentation.Actualizaciones.Views.ActualizacionBannerView"
             x:DataType="vm:ActualizacionBannerViewModel">

    <!-- Franja superior discreta (severity: normal). No bloquea, ancho completo. -->
    <Border Background="#E8F4FD" BorderBrush="#2196F3" BorderThickness="0,0,0,2"
            Padding="16,8"
            Height="56"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Top">
        <Grid ColumnDefinitions="*,Auto">
            <TextBlock Grid.Column="0"
                       Text="{Binding Titulo}"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold" />

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <Button Content="Más tarde"
                        Command="{Binding PosponerCommand}"
                        IsVisible="{Binding EsPosponible}"
                        Background="Transparent"
                        BorderThickness="0" />
                <Button Content="Actualizar ahora"
                        Command="{Binding ActualizarAlReiniciarCommand}"
                        Background="#2196F3"
                        Foreground="White" />
            </StackPanel>
        </Grid>
    </Border>

</UserControl>
