<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:StockApp.Presentation.Actualizaciones"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="350"
             x:Class="StockApp.Presentation.Actualizaciones.Views.ActualizacionBloqueoView"
             x:DataType="vm:ActualizacionBloqueoViewModel">

    <!-- Overlay rojo bloqueante (severity: critical). Sin opción de posponer. -->
    <!-- EsModoDegradado=false → bloqueo normal; EsModoDegradado=true → banner permanente. -->
    <Grid>

        <!-- BloqueoCritico: overlay modal -->
        <Border IsVisible="{Binding !EsModoDegradado}"
                Background="#FFEBEE" BorderBrush="#F44336" BorderThickness="2"
                CornerRadius="6" Padding="24" HorizontalAlignment="Center" VerticalAlignment="Center"
                Width="480">
            <StackPanel Spacing="16">

                <TextBlock Text="Actualizacion critica requerida"
                           FontSize="18" FontWeight="Bold"
                           Foreground="#B71C1C" />

                <TextBlock Text="{Binding TextoMarkdown}"
                           TextWrapping="Wrap"
                           Opacity="0.85" />

                <Button Content="Aplicar y reiniciar"
                        Command="{Binding AplicarYReiniciarCommand}"
                        Background="#F44336"
                        Foreground="White"
                        HorizontalAlignment="Right" />

            </StackPanel>
        </Border>

        <!-- ModoDegradado: banner rojo permanente no-cerrable en la parte superior -->
        <Border IsVisible="{Binding EsModoDegradado}"
                Background="#B71C1C"
                Padding="12,6"
                VerticalAlignment="Top">
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="MODO DEGRADADO — Actualizacion critica no descargada. Reintentara al reiniciar."
                           Foreground="White"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

    </Grid>

</UserControl>
