<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:StockApp.Presentation.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="StockApp.Presentation.Views.InicioView"
             x:DataType="vm:InicioViewModel">

    <Grid>

        <Image Source="avares://StockApp.Presentation/Assets/carmelo-original.png"
               Opacity="0.28"
               Stretch="Uniform"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               RenderTransform="scale(0.85)" />

        <ScrollViewer>
            <StackPanel Margin="24" Spacing="20">

            <!-- Encabezado -->
            <Border Classes="card">
                <StackPanel Spacing="4">
                    <TextBlock Text="{Binding Saludo}"
                               Classes="titulo-vista" />

                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="Sesión iniciada como"
                                   FontSize="14"
                                   Opacity="0.6" />
                        <TextBlock Text="{Binding RolTexto}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Opacity="0.6" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Aviso de vencimientos -->
            <Border Classes="card" IsVisible="{Binding MostrarAvisoVencimientos}">
                <StackPanel Spacing="8">
                    <TextBlock Text="Vencimientos de facturas" Classes="seccion" Foreground="{DynamicResource DangerBrush}" />
                    <TextBlock Text="{Binding CantidadVencidas, StringFormat='{}{0} factura(s) vencida(s)'}"
                               IsVisible="{Binding CantidadVencidas}" />
                    <TextBlock Text="{Binding CantidadAVencer7Dias, StringFormat='{}{0} factura(s) a vencer esta semana'}"
                               IsVisible="{Binding CantidadAVencer7Dias}" />
                    <Button Content="Ver calendario de pagos" Command="{Binding IrACalendarioPagosCommand}" />
                </StackPanel>
            </Border>

            <!-- Accesos rápidos -->
            <Border Classes="card">
                <StackPanel Spacing="12">

                    <TextBlock Text="Accesos rápidos"
                               Classes="seccion" />

                    <WrapPanel>

                        <Button Command="{Binding IrAProductosCommand}"
                                Width="200"
                                Height="90"
                                Background="{DynamicResource FondoBrush}"
                                BorderBrush="{DynamicResource BordeBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Margin="0,0,12,12"
                                Padding="16">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Productos"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="Ver y administrar el catálogo"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Opacity="0.6" />
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding IrARegistrarEntradaCommand}"
                                Width="200"
                                Height="90"
                                Background="{DynamicResource FondoBrush}"
                                BorderBrush="{DynamicResource BordeBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Margin="0,0,12,12"
                                Padding="16">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Registrar Entrada"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="Cargar entradas de stock"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Opacity="0.6" />
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding IrARegistrarSalidaCommand}"
                                Width="200"
                                Height="90"
                                Background="{DynamicResource FondoBrush}"
                                BorderBrush="{DynamicResource BordeBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Margin="0,0,12,12"
                                Padding="16">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Registrar Salida"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="Cargar salidas de stock"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Opacity="0.6" />
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding IrAHistorialMovimientosCommand}"
                                Width="200"
                                Height="90"
                                Background="{DynamicResource FondoBrush}"
                                BorderBrush="{DynamicResource BordeBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Margin="0,0,12,12"
                                Padding="16">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Historial de movimientos"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="Consultar movimientos registrados"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Opacity="0.6" />
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding IrAValorizacionCommand}"
                                IsVisible="{Binding EsAdmin}"
                                Width="200"
                                Height="90"
                                Background="{DynamicResource FondoBrush}"
                                BorderBrush="{DynamicResource BordeBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Margin="0,0,12,12"
                                Padding="16">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Valorización de inventario"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="Ver el valor total del stock"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Opacity="0.6" />
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding IrAAuditoriaCommand}"
                                IsVisible="{Binding EsAdmin}"
                                Width="200"
                                Height="90"
                                Background="{DynamicResource FondoBrush}"
                                BorderBrush="{DynamicResource BordeBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Margin="0,0,12,12"
                                Padding="16">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Log de auditoría"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="Revisar la actividad del sistema"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Opacity="0.6" />
                            </StackPanel>
                        </Button>

                    </WrapPanel>

                </StackPanel>
            </Border>

        </StackPanel>
        </ScrollViewer>

    </Grid>

</UserControl>
