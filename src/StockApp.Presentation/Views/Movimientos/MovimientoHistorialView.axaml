<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:StockApp.Presentation.ViewModels.Movimientos"
             xmlns:dto="using:StockApp.Application.Movimientos"
             xmlns:beh="using:StockApp.Presentation.Behaviors"
             xmlns:conv="using:StockApp.Presentation.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="600"
             x:Class="StockApp.Presentation.Views.Movimientos.MovimientoHistorialView"
             x:DataType="vm:MovimientoHistorialViewModel">

    <DockPanel Margin="24">

        <TextBlock DockPanel.Dock="Top"
                   Text="Historial de movimientos"
                   Classes="titulo-vista"
                   Margin="0,0,0,16" />

        <Border Classes="card">
            <Grid RowDefinitions="Auto,Auto,*">

                <!-- Barra de filtros -->
                <WrapPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                    <StackPanel Spacing="4" Margin="0,0,12,8">
                        <TextBlock Text="Producto" Classes="caption" />
                        <ComboBox ItemsSource="{Binding Productos}"
                                  SelectedItem="{Binding ProductoFiltroSeleccionado}"
                                  MinWidth="180">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Nombre}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Spacing="4" Margin="0,0,12,8">
                        <TextBlock Text="Tipo" Classes="caption" />
                        <ComboBox ItemsSource="{Binding TiposDisponibles}"
                                  SelectedItem="{Binding TipoFiltroSeleccionado}"
                                  MinWidth="140">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Nombre}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Spacing="4" Margin="0,0,12,8">
                        <TextBlock Text="Desde" Classes="caption" />
                        <CalendarDatePicker SelectedDate="{Binding FechaDesde}"
                                            PlaceholderText="dd/mm/aaaa"
                                            SelectedDateFormat="Custom"
                                            CustomDateFormatString="dd/MM/yyyy"
                                            beh:CalendarDatePickerFechaBehavior.NormalizarFechaTipeada="True" />
                    </StackPanel>

                    <StackPanel Spacing="4" Margin="0,0,12,8">
                        <TextBlock Text="Hasta" Classes="caption" />
                        <CalendarDatePicker SelectedDate="{Binding FechaHasta}"
                                            PlaceholderText="dd/mm/aaaa"
                                            SelectedDateFormat="Custom"
                                            CustomDateFormatString="dd/MM/yyyy"
                                            beh:CalendarDatePickerFechaBehavior.NormalizarFechaTipeada="True" />
                    </StackPanel>

                    <StackPanel Spacing="4" VerticalAlignment="Bottom" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Classes="primary"
                                Content="Buscar"
                                Command="{Binding BuscarCommand}"
                                Margin="0,0,8,0" />
                        <Button Classes="secondary"
                                Content="Recalcular stock"
                                Command="{Binding RecalcularCommand}" />
                    </StackPanel>
                </WrapPanel>

                <!-- Producto a recalcular -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Margin="0,0,0,12">
                    <TextBlock Text="Producto a recalcular (ID):" VerticalAlignment="Center" />
                    <NumericUpDown Value="{Binding ProductoIdParaRecalcular}" Minimum="0" Width="140"
                                   FormatString="0" Increment="1" />
                </StackPanel>

                <!-- Listado -->
                <DataGrid Grid.Row="2"
                          ItemsSource="{Binding ItemsView}"
                          IsReadOnly="True"
                          CanUserSortColumns="True"
                          CanUserResizeColumns="True"
                          GridLinesVisibility="Horizontal">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Fecha" Binding="{Binding Fecha, Converter={x:Static conv:FechaUtcALocalConverter.Instance}, StringFormat='dd/MM/yyyy HH:mm', DataType={x:Type dto:MovimientoHistorialDto}}" Width="Auto" />
                        <DataGridTemplateColumn Header="Producto" Width="2*" SortMemberPath="ProductoNombre">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="dto:MovimientoHistorialDto">
                                    <TextBlock Text="{Binding ProductoNombre}"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip.Tip="{Binding ProductoNombre}"
                                               VerticalAlignment="Center" Margin="4,0" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Tipo" Binding="{Binding TipoNombre, DataType={x:Type dto:MovimientoHistorialDto}}" Width="Auto" />
                        <DataGridTextColumn Header="Motivo" Binding="{Binding MotivoNombre, DataType={x:Type dto:MovimientoHistorialDto}}" Width="Auto" />
                        <DataGridTextColumn Header="Cantidad" Binding="{Binding Cantidad, DataType={x:Type dto:MovimientoHistorialDto}}" Width="Auto" />
                        <DataGridTextColumn Header="Precio" Binding="{Binding PrecioUnitario, StringFormat='$ {0:F2}', DataType={x:Type dto:MovimientoHistorialDto}}" Width="Auto" />
                        <DataGridTextColumn Header="Stock ant." Binding="{Binding StockAnterior, DataType={x:Type dto:MovimientoHistorialDto}}" Width="Auto" />
                        <DataGridTextColumn Header="Stock nuevo" Binding="{Binding StockNuevo, DataType={x:Type dto:MovimientoHistorialDto}}" Width="Auto" />
                        <DataGridTextColumn Header="Usuario" Binding="{Binding UsuarioNombre, DataType={x:Type dto:MovimientoHistorialDto}}" Width="Auto" />
                        <DataGridTemplateColumn Header="Comentario" Width="3*" SortMemberPath="Comentario">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="dto:MovimientoHistorialDto">
                                    <TextBlock Text="{Binding Comentario}"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip.Tip="{Binding Comentario}"
                                               VerticalAlignment="Center" Margin="4,0" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

            </Grid>
        </Border>

    </DockPanel>

</UserControl>
