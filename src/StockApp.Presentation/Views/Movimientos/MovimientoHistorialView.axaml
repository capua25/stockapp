<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:StockApp.Presentation.ViewModels.Movimientos"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="StockApp.Presentation.Views.Movimientos.MovimientoHistorialView"
             x:DataType="vm:MovimientoHistorialViewModel">

    <Grid RowDefinitions="Auto,*">

        <!-- Barra de filtros -->
        <Border Grid.Row="0" Padding="16,8" Background="#F5F5F5">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Buscar"
                        Command="{Binding BuscarCommand}" />
                <Button Content="Recalcular stock"
                        Command="{Binding RecalcularCommand}" />
            </StackPanel>
        </Border>

        <!-- Listado -->
        <ListBox Grid.Row="1"
                 ItemsSource="{Binding Items}"
                 Margin="8">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding ProductoNombre}" />
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

    </Grid>

</UserControl>
