<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:StockApp.Presentation.ViewModels.Catalogo"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="700" d:DesignHeight="500"
             x:Class="StockApp.Presentation.Views.Catalogo.ProductoListView"
             x:DataType="vm:ProductoListViewModel">

    <DockPanel Margin="24">

        <TextBlock DockPanel.Dock="Top"
                   Text="Productos"
                   Classes="titulo-vista"
                   Margin="0,0,0,16" />

        <Border Classes="card">
            <DockPanel>

                <!-- Encabezado con búsqueda y botón nuevo -->
                <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto,Auto" RowDefinitions="Auto" Margin="0,0,0,12">
                    <TextBox Grid.Column="0"
                             Text="{Binding FiltroBusqueda}"
                             PlaceholderText="Buscar por nombre, SKU o código de barras..."
                             Margin="0,0,8,0" />
                    <Button Grid.Column="1"
                            Classes="secondary"
                            Content="Buscar"
                            Command="{Binding BuscarCommand}"
                            Margin="0,0,8,0" />
                    <Button Grid.Column="2"
                            Classes="primary"
                            Content="Nuevo"
                            Command="{Binding NuevoCommand}" />
                </Grid>

                <!-- Listado -->
                <ListBox ItemsSource="{Binding Items}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="16" Margin="4">
                                <TextBlock Text="{Binding Codigo}" Width="100" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding Nombre}" Width="250" />
                                <TextBlock Text="{Binding PrecioVenta, StringFormat='$ {0:F2}'}" Width="100" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

            </DockPanel>
        </Border>

    </DockPanel>

</UserControl>
