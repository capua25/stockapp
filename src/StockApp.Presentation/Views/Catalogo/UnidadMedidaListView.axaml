<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:StockApp.Presentation.ViewModels.Catalogo"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="400"
             x:Class="StockApp.Presentation.Views.Catalogo.UnidadMedidaListView"
             x:DataType="vm:UnidadMedidaListViewModel">

    <DockPanel Margin="24">

        <TextBlock DockPanel.Dock="Top"
                   Text="Unidades de medida"
                   Classes="titulo-vista"
                   Margin="0,0,0,16" />

        <Border Classes="card">
            <DockPanel>

                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
                    <Button Classes="primary"
                            Content="Nueva unidad"
                            Command="{Binding NuevoCommand}" />
                    <Button Classes="secondary"
                            Content="Dar de baja"
                            Command="{Binding BajaCommand}" />
                </StackPanel>

                <ListBox ItemsSource="{Binding Items}"
                         SelectedItem="{Binding ItemSeleccionado}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="16" Margin="4">
                                <TextBlock Text="{Binding Nombre}"       Width="200" />
                                <TextBlock Text="{Binding Abreviatura}"  Width="100" Opacity="0.7" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

            </DockPanel>
        </Border>

    </DockPanel>

</UserControl>
