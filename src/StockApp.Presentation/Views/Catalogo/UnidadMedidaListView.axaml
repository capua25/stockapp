<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:StockApp.Presentation.ViewModels.Catalogo"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="400"
             x:Class="StockApp.Presentation.Views.Catalogo.UnidadMedidaListView"
             x:DataType="vm:UnidadMedidaListViewModel">

    <DockPanel Margin="16">

        <StackPanel DockPanel.Dock="Top" Spacing="8" Margin="0,0,0,12">

            <TextBlock Text="Unidades de medida"
                       FontSize="20"
                       FontWeight="Bold" />

            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Nueva unidad"
                        Command="{Binding NuevoCommand}" />
                <Button Content="Dar de baja"
                        Command="{Binding BajaCommand}" />
            </StackPanel>

        </StackPanel>

        <ListBox ItemsSource="{Binding Items}"
                 SelectedItem="{Binding ItemSeleccionado}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="16" Margin="4">
                        <TextBlock Text="{Binding Nombre}"       Width="200" />
                        <TextBlock Text="{Binding Abreviatura}"  Width="100" Opacity="0.7" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

    </DockPanel>

</UserControl>
