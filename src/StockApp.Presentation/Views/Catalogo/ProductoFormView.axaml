<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:StockApp.Presentation.ViewModels.Catalogo"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="450"
             x:Class="StockApp.Presentation.Views.Catalogo.ProductoFormView"
             x:DataType="vm:ProductoFormViewModel">

    <ScrollViewer>
        <Border Classes="card" Padding="24" Margin="24" MaxWidth="480">
            <StackPanel Spacing="12">

                <TextBlock Text="Nuevo producto"
                           Classes="titulo-vista"
                           Margin="0,0,0,8" />

                <StackPanel Spacing="4">
                    <TextBlock Text="SKU (obligatorio)" />
                    <TextBox Text="{Binding Codigo}"
                             PlaceholderText="Ej: P001" />
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="Nombre (obligatorio)" />
                    <TextBox Text="{Binding Nombre}"
                             PlaceholderText="Nombre del producto" />
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="Código de barras" />
                    <TextBox Text="{Binding CodigoBarras}"
                             PlaceholderText="EAN (opcional)" />
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="Descripción" />
                    <TextBox Text="{Binding Descripcion}"
                             PlaceholderText="Descripción opcional"
                             AcceptsReturn="True"
                             Height="60" />
                </StackPanel>

                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto">
                    <TextBlock Grid.Column="0" Text="Precio costo" Margin="0,0,8,4" />
                    <TextBlock Grid.Column="1" Text="Precio venta" Margin="0,0,0,4" />
                    <TextBox Grid.Row="1" Grid.Column="0"
                             Text="{Binding PrecioCosto}"
                             Margin="0,0,8,0" />
                    <TextBox Grid.Row="1" Grid.Column="1"
                             Text="{Binding PrecioVenta}" />
                </Grid>

                <StackPanel Spacing="4">
                    <TextBlock Text="Unidad de medida" />
                    <ComboBox ItemsSource="{Binding UnidadesMedida}"
                              SelectedItem="{Binding UnidadMedidaSeleccionada}"
                              HorizontalAlignment="Stretch">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Nombre}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="Categoría" />
                    <ComboBox ItemsSource="{Binding Categorias}"
                              SelectedItem="{Binding CategoriaSeleccionada}"
                              PlaceholderText="Sin categoría"
                              HorizontalAlignment="Stretch">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Nombre}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <!-- Mensaje de error -->
                <TextBlock Text="{Binding MensajeError}"
                           Foreground="{DynamicResource DangerBrush}"
                           IsVisible="{Binding MensajeError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                           TextWrapping="Wrap" />

                <Button Classes="primary"
                        Content="Guardar"
                        Command="{Binding GuardarCommand}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center" />

            </StackPanel>
        </Border>
    </ScrollViewer>

</UserControl>
