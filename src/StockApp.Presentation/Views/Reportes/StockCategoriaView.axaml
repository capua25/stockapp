<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:StockApp.Presentation.ViewModels.Reportes"
             xmlns:dto="using:StockApp.Application.Reportes"
             xmlns:conv="using:StockApp.Presentation.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
             x:Class="StockApp.Presentation.Views.Reportes.StockCategoriaView"
             x:DataType="vm:StockCategoriaViewModel">

    <DockPanel Margin="24">

        <TextBlock DockPanel.Dock="Top"
                   Text="Stock por categoría"
                   Classes="titulo-vista"
                   Margin="0,0,0,16" />

        <Border Classes="card">
            <Grid RowDefinitions="Auto,*">

                <!-- Barra de acciones -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
                    <Button Classes="primary" Content="Buscar" Command="{Binding BuscarCommand}" />
                    <Button Classes="secondary" Content="Exportar CSV" Command="{Binding ExportarCommand}" />
                </StackPanel>

                <!-- Grilla de stock por categoría -->
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding Items}"
                          IsReadOnly="True"
                          CanUserResizeColumns="True"
                          GridLinesVisibility="Horizontal"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto">
                    <DataGrid.Styles>
                        <Style Selector="DataGridCell.num">
                            <Setter Property="HorizontalContentAlignment" Value="Right" />
                        </Style>
                    </DataGrid.Styles>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Categoría" Width="*" SortMemberPath="Categoria">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="dto:StockCategoriaDto">
                                    <TextBlock Text="{Binding Categoria}"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip.Tip="{Binding Categoria}"
                                               VerticalAlignment="Center" Margin="4,0" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Productos"
                                             Binding="{Binding CantidadProductos, Converter={x:Static conv:CantidadConverter.Instance}}"
                                             Width="Auto" MinWidth="80" CellStyleClasses="num" />
                        <DataGridTemplateColumn Header="Stock Total" Width="Auto" MinWidth="100" SortMemberPath="StockTotal">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="dto:StockCategoriaDto">
                                    <TextBlock Text="{Binding StockTotal, Converter={x:Static conv:CantidadConverter.Instance}}"
                                               Foreground="{Binding StockTotal, Converter={x:Static conv:SignoNegativoBrushConverter.Instance}}"
                                               VerticalAlignment="Center" HorizontalAlignment="Right" Margin="4,0" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Valor Costo"
                                             Binding="{Binding ValorCosto, Converter={x:Static conv:MonedaConverter.Instance}}"
                                             Width="Auto" MinWidth="100" CellStyleClasses="num" />
                        <DataGridTextColumn Header="Valor Venta"
                                             Binding="{Binding ValorVenta, Converter={x:Static conv:MonedaConverter.Instance}}"
                                             Width="Auto" MinWidth="100" CellStyleClasses="num" />
                    </DataGrid.Columns>
                </DataGrid>

            </Grid>
        </Border>

    </DockPanel>

</UserControl>
