<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:StockApp.Presentation.ViewModels.Reportes"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
             x:Class="StockApp.Presentation.Views.Reportes.StockCategoriaView"
             x:DataType="vm:StockCategoriaViewModel">

    <DockPanel Margin="24">

        <TextBlock DockPanel.Dock="Top"
                   Text="Stock por categoría"
                   Classes="titulo-vista"
                   Margin="0,0,0,16" />

        <Border Classes="card">
            <Grid RowDefinitions="Auto,*">

                <!-- Barra de acciones -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
                    <Button Classes="primary" Content="Buscar" Command="{Binding BuscarCommand}" />
                    <Button Classes="secondary" Content="Exportar CSV" Command="{Binding ExportarCommand}" />
                </StackPanel>

                <!-- Grilla de stock por categoría -->
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding Items}"
                          IsReadOnly="True"
                          CanUserResizeColumns="True"
                          GridLinesVisibility="Horizontal">
                    <DataGrid.Styles>
                        <Style Selector="DataGridCell.num">
                            <Setter Property="HorizontalContentAlignment" Value="Right" />
                        </Style>
                    </DataGrid.Styles>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Categoría" Binding="{Binding Categoria}" Width="*" />
                        <DataGridTextColumn Header="Productos" Binding="{Binding CantidadProductos}" Width="140"
                                            CellStyleClasses="num" />
                        <DataGridTextColumn Header="Stock Total" Binding="{Binding StockTotal}" Width="140"
                                            CellStyleClasses="num" />
                        <DataGridTextColumn Header="Valor Costo" Binding="{Binding ValorCosto}" Width="140"
                                            CellStyleClasses="num" />
                        <DataGridTextColumn Header="Valor Venta" Binding="{Binding ValorVenta}" Width="140"
                                            CellStyleClasses="num" />
                    </DataGrid.Columns>
                </DataGrid>

            </Grid>
        </Border>

    </DockPanel>

</UserControl>
