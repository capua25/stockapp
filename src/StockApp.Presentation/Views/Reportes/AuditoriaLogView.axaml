<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:StockApp.Presentation.ViewModels.Reportes"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="600"
             x:Class="StockApp.Presentation.Views.Reportes.AuditoriaLogView"
             x:DataType="vm:AuditoriaLogViewModel">
    <Grid RowDefinitions="Auto,*">

        <!-- Filtros + acciones -->
        <Border Grid.Row="0" Padding="16,8" Background="#F5F5F5">
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="Usuario ID:" VerticalAlignment="Center" />
                <NumericUpDown Value="{Binding UsuarioId}" Minimum="0" Width="120"
                               FormatString="0" Increment="1" />
                <TextBlock Text="Desde:" VerticalAlignment="Center" />
                <DatePicker SelectedDate="{Binding FechaDesde}" />
                <TextBlock Text="Hasta:" VerticalAlignment="Center" />
                <DatePicker SelectedDate="{Binding FechaHasta}" />
                <Button Content="Buscar" Command="{Binding BuscarCommand}" />
                <Button Content="Exportar CSV" Command="{Binding ExportarCommand}" />
            </StackPanel>
        </Border>

        <!-- Grilla de auditoría -->
        <DataGrid Grid.Row="1"
                  Margin="8"
                  ItemsSource="{Binding Items}"
                  IsReadOnly="True"
                  CanUserResizeColumns="True"
                  GridLinesVisibility="Horizontal">
            <DataGrid.Styles>
                <Style Selector="DataGridCell.num">
                    <Setter Property="HorizontalContentAlignment" Value="Right" />
                </Style>
            </DataGrid.Styles>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Fecha" Binding="{Binding Fecha}" Width="160" />
                <DataGridTextColumn Header="Usuario" Binding="{Binding NombreUsuario}" Width="150" />
                <DataGridTextColumn Header="Acción" Binding="{Binding Accion}" Width="160" />
                <DataGridTextColumn Header="Entidad" Binding="{Binding Entidad}" Width="120" />
                <DataGridTextColumn Header="Entidad ID" Binding="{Binding EntidadId}" Width="110"
                                    CellStyleClasses="num" />
                <DataGridTextColumn Header="Detalle" Binding="{Binding Detalle}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>

    </Grid>
</UserControl>
