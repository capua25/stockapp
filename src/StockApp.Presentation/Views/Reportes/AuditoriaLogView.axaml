<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:StockApp.Presentation.ViewModels.Reportes"
             xmlns:conv="using:StockApp.Presentation.Converters"
             xmlns:beh="using:StockApp.Presentation.Behaviors"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="600"
             x:Class="StockApp.Presentation.Views.Reportes.AuditoriaLogView"
             x:DataType="vm:AuditoriaLogViewModel">

    <DockPanel Margin="24">

        <TextBlock DockPanel.Dock="Top"
                   Text="Auditoría"
                   Classes="titulo-vista"
                   Margin="0,0,0,16" />

        <Border Classes="card">
            <Grid RowDefinitions="Auto,Auto,*">

                <!-- Filtros + acciones -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Margin="0,0,0,12">
                    <TextBlock Text="Usuario ID:" VerticalAlignment="Center" />
                    <NumericUpDown Value="{Binding UsuarioId}" Minimum="0" Width="120"
                                   FormatString="0" Increment="1" />
                    <TextBlock Text="Desde:" VerticalAlignment="Center" />
                    <CalendarDatePicker SelectedDate="{Binding FechaDesde}"
                                        PlaceholderText="dd/mm/aaaa"
                                        SelectedDateFormat="Custom"
                                        CustomDateFormatString="dd/MM/yyyy"
                                        beh:CalendarDatePickerFechaBehavior.NormalizarFechaTipeada="True" />
                    <TextBlock Text="Hasta:" VerticalAlignment="Center" />
                    <CalendarDatePicker SelectedDate="{Binding FechaHasta}"
                                        PlaceholderText="dd/mm/aaaa"
                                        SelectedDateFormat="Custom"
                                        CustomDateFormatString="dd/MM/yyyy"
                                        beh:CalendarDatePickerFechaBehavior.NormalizarFechaTipeada="True" />
                    <Button Classes="primary" Content="Buscar" Command="{Binding BuscarCommand}" />
                    <Button Classes="secondary" Content="Exportar CSV" Command="{Binding ExportarCommand}" />
                </StackPanel>

                <!-- Mensaje de error -->
                <TextBlock Grid.Row="1"
                           Text="{Binding MensajeError}"
                           Foreground="{DynamicResource DangerBrush}"
                           IsVisible="{Binding MensajeError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                           Margin="0,0,0,12"
                           TextWrapping="Wrap" />

                <!-- Grilla de auditoría -->
                <DataGrid Grid.Row="2"
                          ItemsSource="{Binding Items}"
                          IsReadOnly="True"
                          CanUserResizeColumns="True"
                          GridLinesVisibility="Horizontal">
                    <DataGrid.Styles>
                        <Style Selector="DataGridCell.num">
                            <Setter Property="HorizontalContentAlignment" Value="Right" />
                        </Style>
                    </DataGrid.Styles>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Fecha" Binding="{Binding Fecha, Converter={x:Static conv:FechaUtcALocalConverter.Instance}, StringFormat='dd/MM/yyyy HH:mm'}" Width="160" />
                        <DataGridTextColumn Header="Usuario" Binding="{Binding NombreUsuario}" Width="150" />
                        <DataGridTextColumn Header="Acción" Binding="{Binding Accion}" Width="160" />
                        <DataGridTextColumn Header="Entidad" Binding="{Binding Entidad}" Width="120" />
                        <DataGridTextColumn Header="Entidad ID" Binding="{Binding EntidadId}" Width="110"
                                            CellStyleClasses="num" />
                        <DataGridTextColumn Header="Detalle" Binding="{Binding Detalle}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Empty state: solo visible cuando no hay resultados cargados -->
                <TextBlock Grid.Row="2"
                           Text="Realizá una búsqueda para ver resultados"
                           Classes="caption"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           IsVisible="{Binding Items, Converter={x:Static conv:ColeccionVaciaConverter.Instance}}" />

            </Grid>
        </Border>

    </DockPanel>

</UserControl>
