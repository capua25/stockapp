<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:StockApp.Presentation.ViewModels.Reportes"
             xmlns:dto="using:StockApp.Application.Reportes"
             xmlns:conv="using:StockApp.Presentation.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
             x:Class="StockApp.Presentation.Views.Reportes.ValorizacionView"
             x:DataType="vm:ValorizacionViewModel">

    <DockPanel Margin="24">

        <TextBlock DockPanel.Dock="Top"
                   Text="Valorización de inventario"
                   Classes="titulo-vista"
                   Margin="0,0,0,16" />

        <Border Classes="card">
            <Grid RowDefinitions="Auto,*,Auto">

                <!-- Barra de acciones -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
                    <Button Classes="primary" Content="Buscar" Command="{Binding BuscarCommand}" />
                    <Button Classes="secondary" Content="Exportar CSV" Command="{Binding ExportarCommand}" />
                </StackPanel>

                <!-- Grilla de valorización -->
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding Items}"
                          IsReadOnly="True"
                          CanUserResizeColumns="True"
                          GridLinesVisibility="Horizontal"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto">
                    <DataGrid.Styles>
                        <!-- Columnas numéricas (montos) alineadas a la derecha. -->
                        <Style Selector="DataGridCell.num">
                            <Setter Property="HorizontalContentAlignment" Value="Right" />
                        </Style>
                    </DataGrid.Styles>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Código" Binding="{Binding Codigo}" Width="Auto" MinWidth="80" />
                        <DataGridTemplateColumn Header="Nombre" Width="2*" SortMemberPath="Nombre">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="dto:ValorizacionItemDto">
                                    <TextBlock Text="{Binding Nombre}"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip.Tip="{Binding Nombre}"
                                               VerticalAlignment="Center" Margin="4,0" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Categoría" Width="*" SortMemberPath="Categoria">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="dto:ValorizacionItemDto">
                                    <TextBlock Text="{Binding Categoria}"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip.Tip="{Binding Categoria}"
                                               VerticalAlignment="Center" Margin="4,0" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Stock" Width="Auto" MinWidth="100" SortMemberPath="StockActual">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate x:DataType="dto:ValorizacionItemDto">
                                    <TextBlock Text="{Binding StockActual, Converter={x:Static conv:CantidadConverter.Instance}}"
                                               Foreground="{Binding StockActual, Converter={x:Static conv:SignoNegativoBrushConverter.Instance}}"
                                               VerticalAlignment="Center" HorizontalAlignment="Right" Margin="4,0" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="P. Costo"
                                             Binding="{Binding PrecioCosto, Converter={x:Static conv:MonedaConverter.Instance}}"
                                             Width="Auto" MinWidth="100" CellStyleClasses="num" />
                        <DataGridTextColumn Header="P. Venta"
                                             Binding="{Binding PrecioVenta, Converter={x:Static conv:MonedaConverter.Instance}}"
                                             Width="Auto" MinWidth="100" CellStyleClasses="num" />
                        <DataGridTextColumn Header="Valor Costo"
                                             Binding="{Binding ValorCosto, Converter={x:Static conv:MonedaConverter.Instance}}"
                                             Width="Auto" MinWidth="100" CellStyleClasses="num" />
                        <DataGridTextColumn Header="Valor Venta"
                                             Binding="{Binding ValorVenta, Converter={x:Static conv:MonedaConverter.Instance}}"
                                             Width="Auto" MinWidth="100" CellStyleClasses="num" />
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Totales -->
                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            Spacing="24"
                            Margin="0,12,0,0"
                            IsVisible="{Binding Totales, Converter={x:Static ObjectConverters.IsNotNull}}">
                    <TextBlock Text="Total Valor Costo:" Classes="seccion" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding Totales.TotalValorCosto, Converter={x:Static conv:MonedaConverter.Instance}}"
                               Classes="body" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <TextBlock Text="Total Valor Venta:" Classes="seccion" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding Totales.TotalValorVenta, Converter={x:Static conv:MonedaConverter.Instance}}"
                               Classes="body" FontWeight="SemiBold" VerticalAlignment="Center" />
                </StackPanel>

            </Grid>
        </Border>

    </DockPanel>

</UserControl>
