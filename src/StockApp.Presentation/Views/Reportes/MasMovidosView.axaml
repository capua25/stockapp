<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:StockApp.Presentation.ViewModels.Reportes"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
             x:Class="StockApp.Presentation.Views.Reportes.MasMovidosView"
             x:DataType="vm:MasMovidosViewModel">

    <DockPanel Margin="24">

        <TextBlock DockPanel.Dock="Top"
                   Text="Productos más movidos"
                   Classes="titulo-vista"
                   Margin="0,0,0,16" />

        <Border Classes="card">
            <Grid RowDefinitions="Auto,*">

                <!-- Filtros + acciones -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Margin="0,0,0,12">
                    <TextBlock Text="Desde:" VerticalAlignment="Center" />
                    <DatePicker SelectedDate="{Binding FechaDesde}" />
                    <TextBlock Text="Hasta:" VerticalAlignment="Center" />
                    <DatePicker SelectedDate="{Binding FechaHasta}" />
                    <TextBlock Text="Top N:" VerticalAlignment="Center" />
                    <NumericUpDown Value="{Binding TopN}" Minimum="1" Width="120"
                                   FormatString="0" Increment="1" />
                    <Button Classes="primary" Content="Buscar" Command="{Binding BuscarCommand}" />
                    <Button Classes="secondary" Content="Exportar CSV" Command="{Binding ExportarCommand}" />
                </StackPanel>

                <!-- Grilla de más movidos -->
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding Items}"
                          IsReadOnly="True"
                          CanUserResizeColumns="True"
                          GridLinesVisibility="Horizontal">
                    <DataGrid.Styles>
                        <Style Selector="DataGridCell.num">
                            <Setter Property="HorizontalContentAlignment" Value="Right" />
                        </Style>
                    </DataGrid.Styles>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Código" Binding="{Binding Codigo}" Width="120" />
                        <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="*" />
                        <DataGridTextColumn Header="Movimientos" Binding="{Binding CantidadMovimientos}" Width="150"
                                            CellStyleClasses="num" />
                        <DataGridTextColumn Header="Volumen Total" Binding="{Binding VolumenTotal}" Width="150"
                                            CellStyleClasses="num" />
                    </DataGrid.Columns>
                </DataGrid>

            </Grid>
        </Border>

    </DockPanel>

</UserControl>
