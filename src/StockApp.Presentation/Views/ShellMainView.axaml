<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:StockApp.Presentation.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="StockApp.Presentation.Views.ShellMainView"
             x:DataType="vm:ShellMainViewModel">

    <Grid ColumnDefinitions="200,*">

        <!-- Menú lateral -->
        <Border Grid.Column="0"
                Background="#F5F5F5"
                BorderBrush="#DDDDDD"
                BorderThickness="0,0,1,0"
                Padding="8">
            <StackPanel Spacing="4">

                <TextBlock Text="StockApp"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="8,8,8,16" />

                <!-- Productos: visible para Admin y Operador -->
                <Button Content="Productos"
                        Command="{Binding NavProductosCommand}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Background="Transparent" />

                <!-- Movimientos: visible para Admin y Operador -->
                <Button Content="Registrar movimiento"
                        Command="{Binding NavMovimientosCommand}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Background="Transparent" />

                <Button Content="Historial de movimientos"
                        Command="{Binding NavHistorialMovimientosCommand}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Background="Transparent" />

                <!-- Tablas maestras: solo Admin -->
                <TextBlock Text="Tablas maestras"
                           FontWeight="SemiBold"
                           Margin="8,8,0,4"
                           IsVisible="{Binding EsAdmin}"
                           Opacity="0.6" />

                <Button Content="Categorías"
                        Command="{Binding NavCategoriasCommand}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Background="Transparent"
                        IsVisible="{Binding EsAdmin}" />

                <Button Content="Proveedores"
                        Command="{Binding NavProveedoresCommand}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Background="Transparent"
                        IsVisible="{Binding EsAdmin}" />

                <Button Content="Unidades de medida"
                        Command="{Binding NavUnidadesMedidaCommand}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Left"
                        Background="Transparent"
                        IsVisible="{Binding EsAdmin}" />

            </StackPanel>
        </Border>

        <!-- Región de contenido: manejada por INavigationService + ViewLocator -->
        <ContentControl Grid.Column="1"
                        Content="{Binding CurrentContent}" />

    </Grid>

</UserControl>
