<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:StockApp.Presentation.ViewModels"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="StockApp.Presentation.Views.ShellMainView"
             x:DataType="vm:ShellMainViewModel">

    <Grid ColumnDefinitions="232,*" Background="{DynamicResource FondoBrush}">

        <!-- Menú lateral: verde bosque oscuro sólido, look dashboard SaaS -->
        <Border Grid.Column="0"
                Background="{DynamicResource SidebarBrush}"
                Padding="8">
            <DockPanel>

                <!-- Versión de la app: discreta, fija al pie del menú lateral -->
                <TextBlock Text="{Binding VersionTexto}"
                           Classes="caption"
                           Foreground="{DynamicResource SidebarTextoBrush}"
                           DockPanel.Dock="Bottom"
                           Opacity="0.5"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,4" />

                <StackPanel Spacing="4">

                <TextBlock Text="StockApp"
                           Classes="titulo-vista"
                           Foreground="{DynamicResource SidebarTextoBrush}"
                           Margin="8,8,8,16" />

                <!-- Inicio: visible para Admin y Operador -->
                <Button Command="{Binding NavInicioCommand}"
                        Classes="ghost"
                        Classes.active="{Binding SeccionActiva, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=Inicio}"
                        HorizontalAlignment="Stretch">
                    <Grid ColumnDefinitions="Auto,*">
                        <i:Icon Grid.Column="0" Value="mdi-home" Foreground="{DynamicResource SidebarTextoBrush}" />
                        <TextBlock Grid.Column="1" Text="Inicio" VerticalAlignment="Center"
                                   Margin="10,0,0,0" TextTrimming="CharacterEllipsis" />
                    </Grid>
                </Button>

                <!-- Productos: visible para Admin y Operador -->
                <Button Command="{Binding NavProductosCommand}"
                        Classes="ghost"
                        Classes.active="{Binding SeccionActiva, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=Productos}"
                        HorizontalAlignment="Stretch">
                    <Grid ColumnDefinitions="Auto,*">
                        <i:Icon Grid.Column="0" Value="mdi-package-variant" Foreground="{DynamicResource SidebarTextoBrush}" />
                        <TextBlock Grid.Column="1" Text="Productos" VerticalAlignment="Center"
                                   Margin="10,0,0,0" TextTrimming="CharacterEllipsis" />
                    </Grid>
                </Button>

                <!-- Registrar Entrada: visible para Admin y Operador -->
                <Button Command="{Binding NavRegistrarEntradaCommand}"
                        Classes="ghost"
                        Classes.active="{Binding SeccionActiva, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=RegistrarEntrada}"
                        HorizontalAlignment="Stretch">
                    <Grid ColumnDefinitions="Auto,*">
                        <i:Icon Grid.Column="0" Value="mdi-tray-arrow-down" Foreground="{DynamicResource SidebarTextoBrush}" />
                        <TextBlock Grid.Column="1" Text="Registrar Entrada" VerticalAlignment="Center"
                                   Margin="10,0,0,0" TextTrimming="CharacterEllipsis" />
                    </Grid>
                </Button>

                <!-- Registrar Salida: visible para Admin y Operador -->
                <Button Command="{Binding NavRegistrarSalidaCommand}"
                        Classes="ghost"
                        Classes.active="{Binding SeccionActiva, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=RegistrarSalida}"
                        HorizontalAlignment="Stretch">
                    <Grid ColumnDefinitions="Auto,*">
                        <i:Icon Grid.Column="0" Value="mdi-tray-arrow-up" Foreground="{DynamicResource SidebarTextoBrush}" />
                        <TextBlock Grid.Column="1" Text="Registrar Salida" VerticalAlignment="Center"
                                   Margin="10,0,0,0" TextTrimming="CharacterEllipsis" />
                    </Grid>
                </Button>

                <Button Command="{Binding NavHistorialMovimientosCommand}"
                        Classes="ghost"
                        Classes.active="{Binding SeccionActiva, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=HistorialMovimientos}"
                        HorizontalAlignment="Stretch">
                    <Grid ColumnDefinitions="Auto,*">
                        <i:Icon Grid.Column="0" Value="mdi-history" Foreground="{DynamicResource SidebarTextoBrush}" />
                        <TextBlock Grid.Column="1" Text="Historial de movimientos" VerticalAlignment="Center"
                                   Margin="10,0,0,0" TextTrimming="CharacterEllipsis" />
                    </Grid>
                </Button>

                <!-- Tablas maestras: solo Admin -->
                <TextBlock Text="Tablas maestras"
                           Classes="caption"
                           Foreground="{DynamicResource SidebarTextoBrush}"
                           FontWeight="SemiBold"
                           Margin="8,8,0,4"
                           IsVisible="{Binding EsAdmin}"
                           Opacity="0.6" />

                <Button Command="{Binding NavCategoriasCommand}"
                        Classes="ghost"
                        Classes.active="{Binding SeccionActiva, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=Categorias}"
                        HorizontalAlignment="Stretch"
                        IsVisible="{Binding EsAdmin}">
                    <Grid ColumnDefinitions="Auto,*">
                        <i:Icon Grid.Column="0" Value="mdi-shape" Foreground="{DynamicResource SidebarTextoBrush}" />
                        <TextBlock Grid.Column="1" Text="Categorías" VerticalAlignment="Center"
                                   Margin="10,0,0,0" TextTrimming="CharacterEllipsis" />
                    </Grid>
                </Button>

                <Button Command="{Binding NavProveedoresCommand}"
                        Classes="ghost"
                        Classes.active="{Binding SeccionActiva, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=Proveedores}"
                        HorizontalAlignment="Stretch"
                        IsVisible="{Binding EsAdmin}">
                    <Grid ColumnDefinitions="Auto,*">
                        <i:Icon Grid.Column="0" Value="mdi-truck" Foreground="{DynamicResource SidebarTextoBrush}" />
                        <TextBlock Grid.Column="1" Text="Proveedores" VerticalAlignment="Center"
                                   Margin="10,0,0,0" TextTrimming="CharacterEllipsis" />
                    </Grid>
                </Button>

                <Button Command="{Binding NavUnidadesMedidaCommand}"
                        Classes="ghost"
                        Classes.active="{Binding SeccionActiva, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=UnidadesMedida}"
                        HorizontalAlignment="Stretch"
                        IsVisible="{Binding EsAdmin}">
                    <Grid ColumnDefinitions="Auto,*">
                        <i:Icon Grid.Column="0" Value="mdi-ruler" Foreground="{DynamicResource SidebarTextoBrush}" />
                        <TextBlock Grid.Column="1" Text="Unidades de medida" VerticalAlignment="Center"
                                   Margin="10,0,0,0" TextTrimming="CharacterEllipsis" />
                    </Grid>
                </Button>

                <!-- Reportes: solo Admin -->
                <TextBlock Text="Reportes"
                           Classes="caption"
                           Foreground="{DynamicResource SidebarTextoBrush}"
                           FontWeight="SemiBold"
                           Margin="8,8,0,4"
                           IsVisible="{Binding EsAdmin}"
                           Opacity="0.6" />

                <Button Command="{Binding NavValorizacionCommand}"
                        Classes="ghost"
                        Classes.active="{Binding SeccionActiva, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=Valorizacion}"
                        HorizontalAlignment="Stretch"
                        IsVisible="{Binding EsAdmin}">
                    <Grid ColumnDefinitions="Auto,*">
                        <i:Icon Grid.Column="0" Value="mdi-currency-usd" Foreground="{DynamicResource SidebarTextoBrush}" />
                        <TextBlock Grid.Column="1" Text="Valorización de inventario" VerticalAlignment="Center"
                                   Margin="10,0,0,0" TextTrimming="CharacterEllipsis" />
                    </Grid>
                </Button>

                <Button Command="{Binding NavStockCategoriaCommand}"
                        Classes="ghost"
                        Classes.active="{Binding SeccionActiva, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=StockCategoria}"
                        HorizontalAlignment="Stretch"
                        IsVisible="{Binding EsAdmin}">
                    <Grid ColumnDefinitions="Auto,*">
                        <i:Icon Grid.Column="0" Value="mdi-chart-pie" Foreground="{DynamicResource SidebarTextoBrush}" />
                        <TextBlock Grid.Column="1" Text="Stock por categoría" VerticalAlignment="Center"
                                   Margin="10,0,0,0" TextTrimming="CharacterEllipsis" />
                    </Grid>
                </Button>

                <Button Command="{Binding NavHistorialPorProductoCommand}"
                        Classes="ghost"
                        Classes.active="{Binding SeccionActiva, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=HistorialPorProducto}"
                        HorizontalAlignment="Stretch"
                        IsVisible="{Binding EsAdmin}">
                    <Grid ColumnDefinitions="Auto,*">
                        <i:Icon Grid.Column="0" Value="mdi-file-document" Foreground="{DynamicResource SidebarTextoBrush}" />
                        <TextBlock Grid.Column="1" Text="Historial por producto" VerticalAlignment="Center"
                                   Margin="10,0,0,0" TextTrimming="CharacterEllipsis" />
                    </Grid>
                </Button>

                <Button Command="{Binding NavMasMovidosCommand}"
                        Classes="ghost"
                        Classes.active="{Binding SeccionActiva, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=MasMovidos}"
                        HorizontalAlignment="Stretch"
                        IsVisible="{Binding EsAdmin}">
                    <Grid ColumnDefinitions="Auto,*">
                        <i:Icon Grid.Column="0" Value="mdi-trending-up" Foreground="{DynamicResource SidebarTextoBrush}" />
                        <TextBlock Grid.Column="1" Text="Productos más movidos" VerticalAlignment="Center"
                                   Margin="10,0,0,0" TextTrimming="CharacterEllipsis" />
                    </Grid>
                </Button>

                <Button Command="{Binding NavAuditoriaLogCommand}"
                        Classes="ghost"
                        Classes.active="{Binding SeccionActiva, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=AuditoriaLog}"
                        HorizontalAlignment="Stretch"
                        IsVisible="{Binding EsAdmin}">
                    <Grid ColumnDefinitions="Auto,*">
                        <i:Icon Grid.Column="0" Value="mdi-shield-search" Foreground="{DynamicResource SidebarTextoBrush}" />
                        <TextBlock Grid.Column="1" Text="Log de auditoría" VerticalAlignment="Center"
                                   Margin="10,0,0,0" TextTrimming="CharacterEllipsis" />
                    </Grid>
                </Button>

                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Región de contenido: manejada por INavigationService + ViewLocator -->
        <ContentControl Grid.Column="1"
                        Content="{Binding CurrentContent}" />

    </Grid>

</UserControl>
