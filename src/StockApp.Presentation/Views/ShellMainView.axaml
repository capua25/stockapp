<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:StockApp.Presentation.ViewModels"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="StockApp.Presentation.Views.ShellMainView"
             x:DataType="vm:ShellMainViewModel">

    <Grid ColumnDefinitions="200,*">

        <!-- Menú lateral -->
        <Border Grid.Column="0"
                Background="{DynamicResource FondoBrush}"
                BorderBrush="{DynamicResource BordeBrush}"
                BorderThickness="0,0,1,0"
                Padding="8">
            <DockPanel>

                <!-- Versión de la app: discreta, fija al pie del menú lateral -->
                <TextBlock Text="{Binding VersionTexto}"
                           Classes="caption"
                           DockPanel.Dock="Bottom"
                           Opacity="0.5"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,4" />

                <StackPanel Spacing="4">

                <TextBlock Text="StockApp"
                           Classes="titulo-vista"
                           Margin="8,8,8,16" />

                <!-- Productos: visible para Admin y Operador -->
                <Button Command="{Binding NavProductosCommand}"
                        Classes="ghost"
                        Classes.active="{Binding SeccionActiva, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=Productos}"
                        HorizontalAlignment="Stretch">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <i:Icon Value="mdi-package-variant" Foreground="{DynamicResource BrandBrush}" />
                        <TextBlock Text="Productos" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <!-- Movimientos: visible para Admin y Operador -->
                <Button Command="{Binding NavMovimientosCommand}"
                        Classes="ghost"
                        Classes.active="{Binding SeccionActiva, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=Movimientos}"
                        HorizontalAlignment="Stretch">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <i:Icon Value="mdi-swap-horizontal" Foreground="{DynamicResource BrandBrush}" />
                        <TextBlock Text="Registrar movimiento" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Button Command="{Binding NavHistorialMovimientosCommand}"
                        Classes="ghost"
                        Classes.active="{Binding SeccionActiva, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=HistorialMovimientos}"
                        HorizontalAlignment="Stretch">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <i:Icon Value="mdi-history" Foreground="{DynamicResource BrandBrush}" />
                        <TextBlock Text="Historial de movimientos" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <!-- Tablas maestras: solo Admin -->
                <TextBlock Text="Tablas maestras"
                           Classes="caption"
                           FontWeight="SemiBold"
                           Margin="8,8,0,4"
                           IsVisible="{Binding EsAdmin}"
                           Opacity="0.6" />

                <Button Command="{Binding NavCategoriasCommand}"
                        Classes="ghost"
                        Classes.active="{Binding SeccionActiva, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=Categorias}"
                        HorizontalAlignment="Stretch"
                        IsVisible="{Binding EsAdmin}">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <i:Icon Value="mdi-shape" Foreground="{DynamicResource BrandBrush}" />
                        <TextBlock Text="Categorías" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Button Command="{Binding NavProveedoresCommand}"
                        Classes="ghost"
                        Classes.active="{Binding SeccionActiva, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=Proveedores}"
                        HorizontalAlignment="Stretch"
                        IsVisible="{Binding EsAdmin}">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <i:Icon Value="mdi-truck" Foreground="{DynamicResource BrandBrush}" />
                        <TextBlock Text="Proveedores" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Button Command="{Binding NavUnidadesMedidaCommand}"
                        Classes="ghost"
                        Classes.active="{Binding SeccionActiva, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=UnidadesMedida}"
                        HorizontalAlignment="Stretch"
                        IsVisible="{Binding EsAdmin}">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <i:Icon Value="mdi-ruler" Foreground="{DynamicResource BrandBrush}" />
                        <TextBlock Text="Unidades de medida" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <!-- Reportes: solo Admin -->
                <TextBlock Text="Reportes"
                           Classes="caption"
                           FontWeight="SemiBold"
                           Margin="8,8,0,4"
                           IsVisible="{Binding EsAdmin}"
                           Opacity="0.6" />

                <Button Command="{Binding NavValorizacionCommand}"
                        Classes="ghost"
                        Classes.active="{Binding SeccionActiva, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=Valorizacion}"
                        HorizontalAlignment="Stretch"
                        IsVisible="{Binding EsAdmin}">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <i:Icon Value="mdi-currency-usd" Foreground="{DynamicResource BrandBrush}" />
                        <TextBlock Text="Valorización de inventario" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Button Command="{Binding NavStockCategoriaCommand}"
                        Classes="ghost"
                        Classes.active="{Binding SeccionActiva, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=StockCategoria}"
                        HorizontalAlignment="Stretch"
                        IsVisible="{Binding EsAdmin}">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <i:Icon Value="mdi-chart-pie" Foreground="{DynamicResource BrandBrush}" />
                        <TextBlock Text="Stock por categoría" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Button Command="{Binding NavHistorialPorProductoCommand}"
                        Classes="ghost"
                        Classes.active="{Binding SeccionActiva, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=HistorialPorProducto}"
                        HorizontalAlignment="Stretch"
                        IsVisible="{Binding EsAdmin}">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <i:Icon Value="mdi-file-document" Foreground="{DynamicResource BrandBrush}" />
                        <TextBlock Text="Historial por producto" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Button Command="{Binding NavMasMovidosCommand}"
                        Classes="ghost"
                        Classes.active="{Binding SeccionActiva, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=MasMovidos}"
                        HorizontalAlignment="Stretch"
                        IsVisible="{Binding EsAdmin}">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <i:Icon Value="mdi-trending-up" Foreground="{DynamicResource BrandBrush}" />
                        <TextBlock Text="Productos más movidos" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Button Command="{Binding NavAuditoriaLogCommand}"
                        Classes="ghost"
                        Classes.active="{Binding SeccionActiva, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=AuditoriaLog}"
                        HorizontalAlignment="Stretch"
                        IsVisible="{Binding EsAdmin}">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <i:Icon Value="mdi-shield-search" Foreground="{DynamicResource BrandBrush}" />
                        <TextBlock Text="Log de auditoría" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Región de contenido: manejada por INavigationService + ViewLocator -->
        <ContentControl Grid.Column="1"
                        Content="{Binding CurrentContent}" />

    </Grid>

</UserControl>
