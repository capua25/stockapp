<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ════════════════════════════════════════════════════════════════════
         StockApp UI Kit — Controles globales.
         Aditivo sobre FluentTheme: los estilos de Button de acá abajo SOLO
         aplican a controles con clase explícita (Button.primary, Button.
         secondary, Button.ghost, Button.danger, Border.card). Un Button sin
         clase sigue viéndose con el FluentTheme default. TextBox/ComboBox
         SÍ son globales (sin clase requerida): ver Deliverable de la Tarea 2.
         ════════════════════════════════════════════════════════════════════ -->

    <!-- ── Button (global, sin clase requerida) ─────────────────────────────
         Default limpio para botones sin Classes explícitas: evita el gris
         feo de FluentTheme. Los selectores .primary/.secondary/.ghost/.danger
         de abajo tienen mayor especificidad (selector con clase) y ganan
         sobre este default sin importar el orden de declaración. -->
    <Style Selector="Button">
        <Setter Property="Background" Value="{DynamicResource SuperficieBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextoPrimarioBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BordeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="16,8" />
    </Style>
    <Style Selector="Button:pointerover">
        <Setter Property="Background" Value="{DynamicResource BrandSuaveBrush}" />
    </Style>
    <Style Selector="Button:disabled">
        <Setter Property="Background" Value="{DynamicResource DeshabilitadoFondoBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource DeshabilitadoTextoBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource DeshabilitadoBordeBrush}" />
    </Style>

    <!-- ── Button: primary (acción principal) ──────────────────────────────
         Background usa BrandHoverBrush (#15803D), NO BrandBrush (#16A34A):
         blanco sobre #16A34A da ~3.9:1 (insuficiente para AA), sobre #15803D
         da ~5.9:1. Pressed usa SidebarBrush (#14532D, mismo tono que el
         fondo del sidebar) como tercer escalón, más oscuro que BrandPressedBrush. -->
    <Style Selector="Button.primary">
        <Setter Property="Background" Value="{DynamicResource BrandHoverBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="FontWeight" Value="Medium" />
    </Style>
    <Style Selector="Button.primary:pointerover">
        <Setter Property="Background" Value="{DynamicResource BrandPressedBrush}" />
    </Style>
    <Style Selector="Button.primary:pressed">
        <Setter Property="Background" Value="{DynamicResource SidebarBrush}" />
    </Style>
    <Style Selector="Button.primary:disabled">
        <Setter Property="Background" Value="{DynamicResource DeshabilitadoFondoBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource DeshabilitadoTextoBrush}" />
    </Style>

    <!-- ── Button: secondary (outline) ─────────────────────────────────────
         Foreground/BorderBrush usan BrandHoverBrush (#15803D), no BrandBrush,
         por el mismo motivo de contraste que .primary (texto sobre Superficie). -->
    <Style Selector="Button.secondary">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource BrandHoverBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrandHoverBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="FontWeight" Value="Medium" />
    </Style>
    <Style Selector="Button.secondary:pointerover">
        <Setter Property="Background" Value="{DynamicResource BrandSuaveBrush}" />
    </Style>
    <Style Selector="Button.secondary:pressed">
        <Setter Property="Background" Value="{DynamicResource BrandSuaveBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BrandPressedBrush}" />
    </Style>
    <Style Selector="Button.secondary:disabled">
        <Setter Property="Foreground" Value="{DynamicResource DeshabilitadoTextoBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource DeshabilitadoBordeBrush}" />
    </Style>

    <!-- ── Button: ghost (sidebar) ──────────────────────────────────────────
         Único uso actual: ítems de menú del sidebar (ShellMainView), que
         ahora tiene fondo VERDE BOSQUE OSCURO (SidebarBrush). Por eso .ghost
         pasa de estar pensado para fondo claro (Foreground oscuro + hover
         BrandSuave) a texto blanco + overlays translúcidos de blanco. Si en
         el futuro .ghost se usa también sobre fondo claro (toolbar), esto
         necesitará una variante separada. -->
    <Style Selector="Button.ghost">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource SidebarTextoBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
    </Style>
    <Style Selector="Button.ghost:pointerover">
        <Setter Property="Background" Value="{DynamicResource SidebarHoverOverlayBrush}" />
    </Style>
    <Style Selector="Button.ghost:pressed">
        <Setter Property="Background" Value="{DynamicResource SidebarPressedOverlayBrush}" />
    </Style>
    <Style Selector="Button.ghost:disabled">
        <Setter Property="Foreground" Value="{DynamicResource SidebarTextoBrush}" />
        <Setter Property="Opacity" Value="0.5" />
    </Style>
    <!-- Estado activo (Tarea 4, adaptado a fondo oscuro): overlay SidebarActivoBrush
         (#166534, un escalón más claro que el fondo #14532D) + texto blanco +
         seminegrita + barra izquierda de acento en verde brillante (#4ADE80,
         el único lugar donde ese verde vivo se usa como color plano, no como
         fondo de texto, así que no tiene restricción de contraste 4.5:1). -->
    <Style Selector="Button.ghost.active">
        <Setter Property="Background" Value="{DynamicResource SidebarActivoBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource SidebarTextoBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource SidebarAccentBrush}" />
        <Setter Property="BorderThickness" Value="3,0,0,0" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <!-- ── Button: danger (destructivo) ────────────────────────────────────── -->
    <Style Selector="Button.danger">
        <Setter Property="Background" Value="{DynamicResource DangerBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="FontWeight" Value="Medium" />
    </Style>
    <Style Selector="Button.danger:pointerover">
        <Setter Property="Background" Value="{DynamicResource DangerHoverBrush}" />
    </Style>
    <Style Selector="Button.danger:pressed">
        <Setter Property="Background" Value="{DynamicResource DangerPressedBrush}" />
    </Style>
    <Style Selector="Button.danger:disabled">
        <Setter Property="Background" Value="{DynamicResource DeshabilitadoFondoBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource DeshabilitadoTextoBrush}" />
    </Style>

    <!-- ── TextBox (global, sin clase requerida) ────────────────────────────── -->
    <Style Selector="TextBox">
        <Setter Property="Background" Value="{DynamicResource SuperficieBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BordeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="Foreground" Value="{DynamicResource TextoPrimarioBrush}" />
    </Style>
    <Style Selector="TextBox:focus">
        <Setter Property="BorderBrush" Value="{DynamicResource BrandBrush}" />
        <Setter Property="BorderThickness" Value="2" />
    </Style>
    <Style Selector="TextBox.error">
        <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
    </Style>

    <!-- ── ComboBox (global, sin clase requerida) ───────────────────────────── -->
    <Style Selector="ComboBox">
        <Setter Property="Background" Value="{DynamicResource SuperficieBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BordeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="10,8" />
    </Style>
    <Style Selector="ComboBox:focus">
        <Setter Property="BorderBrush" Value="{DynamicResource BrandBrush}" />
        <Setter Property="BorderThickness" Value="2" />
    </Style>
    <Style Selector="ComboBox.error">
        <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
    </Style>

    <!-- ── Card (Border) ────────────────────────────────────────────────────── -->
    <!-- Card blanca "flotando" sobre el fondo claro del área de contenido:
         borde NEUTRO sutil (BordeBrush), no verde — el acento de la vista lo
         da el contenido/título (titulo-vista), no el borde de la card.
         BoxShadow suave es lo que la despega del fondo. -->
    <Style Selector="Border.card">
        <Setter Property="Background" Value="{DynamicResource SuperficieBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BordeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="BoxShadow" Value="0 1 3 0 #1A0F172A" />
    </Style>

</Styles>
